# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:123@localhost:5432/academia_db"

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET="dev-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"

# ─── CORS ────────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173"

# ─── SMTP (Email / Campaigns) ────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Academia Deportiva <your-email@gmail.com>"

VITE_ACADEMY_SLUG=academia-elite

# Cloudinary – complete these after creating an unsigned upload preset in cloudinary.com
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
